<%- include('partials/header') %>

<!-- GALLERY HERO -->
<div class="gallery-hero">
  <h1>Photo Gallery</h1>
  <p>Explore our products, services, and the farming community we serve</p>
</div>

<!-- GALLERY GRID -->
<section>
  <div class="section-header fade-in">
    <span class="section-tag">Our Gallery</span>
    <h2>Products & Services in Action</h2>
    <p>A visual journey through our agricultural service center</p>
    <div class="divider"></div>
  </div>
  <div class="gallery-full-grid">
    <% gallery.forEach(function(item) { %>
    <div class="gallery-item fade-in">
      <img src="<%= item.image_url %>" alt="<%= item.title %>" loading="lazy">
      <div class="gallery-overlay">
        <span><%= item.title %></span>
      </div>
    </div>
    <% }); %>

    <!-- Extra static gallery items -->
    <div class="gallery-item fade-in">
      <img src="https://images.unsplash.com/photo-1586771107445-d3ca888129ff?w=600" alt="Crop Fields" loading="lazy">
      <div class="gallery-overlay"><span>Healthy Crop Fields</span></div>
    </div>
    <div class="gallery-item fade-in">
      <img src="https://images.unsplash.com/photo-1530836369250-ef72a3f5cda8?w=600" alt="Irrigation" loading="lazy">
      <div class="gallery-overlay"><span>Irrigation Systems</span></div>
    </div>
    <div class="gallery-item fade-in">
      <img src="https://images.unsplash.com/photo-1464226184884-fa280b87c399?w=600" alt="Organic Farming" loading="lazy">
      <div class="gallery-overlay"><span>Organic Farming</span></div>
    </div>
    <div class="gallery-item fade-in">
      <img src="https://images.unsplash.com/photo-1592982537447-7440770cbfc9?w=600" alt="Farm Tools" loading="lazy">
      <div class="gallery-overlay"><span>Quality Farm Tools</span></div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <h2>Visit Our Center Today! 🌾</h2>
  <p>See our full range of products and services in person</p>
  <div class="cta-btns">
    <a href="https://maps.google.com/?q=Jatta+Kamamadi+Karnataka+586114" target="_blank" class="btn-white">🗺️ Get Directions</a>
    <a href="/contact" class="btn-transparent">📞 Contact Us</a>
  </div>
</section>

<%- include('partials/footer') %>
