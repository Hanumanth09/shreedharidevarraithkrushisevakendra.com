<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login — Krushi Seva Kendra</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="login-page">
  <div class="login-card">
    <div class="login-logo">
      <div class="icon">🌾</div>
      <h1>Krushi Seva Kendra</h1>
      <p>Admin Panel — Secure Login</p>
    </div>
    <% if (error) { %>
    <div class="alert-error">❌ Invalid username or password. Try again.</div>
    <% } %>
    <form method="POST" action="/admin/login">
      <div class="form-group">
        <label>Username</label>
        <input type="text" name="username" placeholder="Enter username" required autofocus>
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" placeholder="Enter password" required>
      </div>
      <button type="submit" class="btn-login">🔐 Login to Admin Panel</button>
    </form>
    <p style="text-align:center; margin-top:20px; font-size:0.8rem; color:#999;">
      Default: admin / krushi@123
    </p>
  </div>
</div>
</body>
</html>
